	column 'Income Range' =
			
			SWITCH(
			    TRUE(),
			    Customers_Dim[AnnualIncome] <= 50000,"Low Income",
			    Customers_Dim[AnnualIncome] <= 100000,"Average Income",
			    Customers_Dim[AnnualIncome] <= 1500000,"High Income",
			    Customers_Dim[AnnualIncome] >  1500000, "Very High")
